{
  "name": "@codeforward/icons",
  "version": "2.0.0",
  "description": "Brand icons and marks for Codeward",
  "license": "MIT",
  "author": "Vitor Medina",
  "keywords": [
    "react",
    "icons",
    "svg",
    "brand",
    "design-system",
    "codeward"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codeward-Enterprise/Codeward-library.git",
    "directory": "packages/icons"
  },
  "homepage": "https://github.com/Codeward-Enterprise/Codeward-library#readme",
  "bugs": {
    "url": "https://github.com/Codeward-Enterprise/Codeward-library/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
