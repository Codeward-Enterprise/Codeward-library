{
  "name": "@codeforward/cli",
  "version": "1.0.0",
  "description": "CLI for adding Codeward UI components to your project",
  "license": "MIT",
  "author": "Vitor Medina",
  "keywords": [
    "cli",
    "component-library",
    "code-generator",
    "react",
    "tailwindcss",
    "design-system",
    "codeward"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codeward-Enterprise/Codeward-library.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Codeward-Enterprise/Codeward-library#readme",
  "bugs": {
    "url": "https://github.com/Codeward-Enterprise/Codeward-library/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codeward": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.3.0",
    "ora": "^8.1.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
