{
  "name": "@codeforward/utils",
  "version": "1.0.0",
  "description": "Shared utilities for Codeward UI — cn(), BR formatters, validators",
  "license": "MIT",
  "author": "Vitor Medina",
  "keywords": [
    "react",
    "utilities",
    "cn",
    "tailwindcss",
    "brazil",
    "formatters",
    "validators",
    "codeward"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codeward-Enterprise/Codeward-library.git",
    "directory": "packages/utils"
  },
  "homepage": "https://github.com/Codeward-Enterprise/Codeward-library#readme",
  "bugs": {
    "url": "https://github.com/Codeward-Enterprise/Codeward-library/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "private": false,
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "test": "vitest run"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
